{
  "name": "@socialneuron/mcp-server",
  "mcpName": "com.socialneuron/mcp-server",
  "version": "1.8.0",
  "description": "Official MCP server, REST API & CLI for Social Neuron — create, schedule, and optimize social content with 35+ AI models across YouTube, TikTok, and more.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "socialneuron-mcp": "dist/index.js",
    "sn": "dist/sn.js"
  },
  "files": [
    "dist/",
    "tools.lock.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "license": "MIT",
  "author": {
    "name": "Social Neuron",
    "url": "https://socialneuron.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/socialneuron/mcp-server.git"
  },
  "exports": {
    ".": "./dist/index.js",
    "./http": "./dist/http.js"
  },
  "homepage": "https://socialneuron.com/for-developers",
  "bugs": {
    "url": "https://github.com/socialneuron/mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "social-media",
    "social-media-management",
    "content-creation",
    "content-scheduling",
    "marketing",
    "automation",
    "analytics",
    "youtube",
    "tiktok",
    "instagram",
    "linkedin",
    "claude",
    "anthropic",
    "content-marketing",
    "llm-tools",
    "agent-tools"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "lint:lockfile": "node scripts/lint-lockfile.mjs package-lock.json",
    "check:dep-age": "node scripts/check-dep-age.mjs",
    "verify:deps": "node scripts/verify-dependency-contracts.mjs",
    "build": "esbuild src/http.ts --bundle --platform=node --target=es2022 --format=esm --outfile=dist/http.js --packages=external",
    "build:stdio": "esbuild src/index.ts --bundle --platform=node --target=es2022 --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node' --packages=external && chmod +x dist/index.js",
    "prebuild:sn": "node scripts/write-version.mjs",
    "build:sn": "esbuild src/sn.ts --bundle --platform=node --target=es2022 --format=esm --outfile=dist/sn.js --banner:js='#!/usr/bin/env node' --packages=external && chmod +x dist/sn.js",
    "build:lock": "node scripts/build-tools-lock.mjs",
    "build:app": "cd apps/content-calendar && (test -d node_modules || npm install --ignore-scripts --no-audit --no-fund) && npm run build",
    "build:all": "npm run build:stdio && npm run build && npm run build:sn && npm run build:lock && npm run build:app",
    "verify:lock": "node scripts/verify-tools-lock.mjs",
    "lint:tools": "node scripts/lint-tool-descriptions.mjs",
    "start": "node dist/http.js",
    "start:stdio": "node dist/index.js",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "dev": "esbuild src/index.ts --bundle --platform=node --target=es2022 --format=esm --outfile=dist/index.js --sourcemap --banner:js='#!/usr/bin/env node' --packages=external --watch",
    "test": "mkdir -p .tmp-vitest && npm run build:stdio && vitest run --reporter=default --reporter=json --outputFile=.tmp-vitest/results.json && node scripts/verify-vitest-report.mjs .tmp-vitest/results.json",
    "test:watch": "vitest",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run clean && npm run build:all && npm test",
    "build:docs": "node scripts/build-tools-reference.mjs",
    "verify:metadata": "node scripts/verify-metadata.mjs",
    "verify:metadata:live": "node scripts/verify-metadata.mjs --live"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "2.109.0",
    "express": "^5.1.0",
    "jose": "^6.2.1",
    "open": "10.0.0",
    "posthog-node": "5.39.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@remotion/bundler": "4.0.485",
    "@remotion/renderer": "4.0.485",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "esbuild": "^0.28.1",
    "playwright": "1.61.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "vite": "7.3.5",
    "esbuild": "$esbuild",
    "@hono/node-server": "1.19.13",
    "hono": "4.12.27",
    "path-to-regexp": "8.4.2"
  },
  "engines": {
    "node": ">=20.0.0 <21.0.0 || >=22.0.0"
  },
  "peerDependencies": {
    "playwright": "^1.59.1"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
