{
  "name": "@socialneuron/mcp-server",
  "version": "1.7.5-rc.0",
  "description": "MCP server for Social Neuron - AI content creation platform",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "socialneuron-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "tools.lock.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "license": "MIT",
  "author": {
    "name": "Social Neuron",
    "url": "https://socialneuron.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/socialneuron/mcp-server.git"
  },
  "exports": {
    ".": "./dist/index.js",
    "./http": "./dist/http.js"
  },
  "homepage": "https://socialneuron.com/for-developers",
  "bugs": {
    "url": "https://github.com/socialneuron/mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "social-media",
    "social-media-management",
    "content-creation",
    "content-scheduling",
    "marketing",
    "automation",
    "analytics",
    "youtube",
    "tiktok",
    "instagram",
    "linkedin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint:lockfile": "lockfile-lint --path package-lock.json --type npm --validate-https --allowed-hosts npm --validate-package-names --validate-integrity",
    "check:dep-age": "node scripts/check-dep-age.mjs",
    "build": "esbuild src/http.ts --bundle --platform=node --target=es2022 --format=esm --outfile=dist/http.js --packages=external",
    "build:stdio": "esbuild src/index.ts --bundle --platform=node --target=es2022 --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node' --packages=external && chmod +x dist/index.js",
    "build:lock": "node scripts/build-tools-lock.mjs",
    "build:all": "npm run build:stdio && npm run build && npm run build:lock",
    "verify:lock": "node scripts/verify-tools-lock.mjs",
    "lint:tools": "node scripts/lint-tool-descriptions.mjs",
    "start": "node dist/http.js",
    "start:stdio": "node dist/index.js",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "dev": "esbuild src/index.ts --bundle --platform=node --target=es2022 --format=esm --outfile=dist/index.js --sourcemap --banner:js='#!/usr/bin/env node' --packages=external --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist/",
    "prepublishOnly": "npm run clean && npm run build:all && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "2.102.1",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "jose": "^6.2.1",
    "open": "10.0.0",
    "posthog-node": "^5.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "esbuild": "^0.28.0",
    "lockfile-lint": "5.0.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "vite": "7.3.2",
    "@hono/node-server": "1.19.13",
    "hono": "4.12.14",
    "path-to-regexp": "8.4.2"
  },
  "engines": {
    "node": ">=20.0.0 <21.0.0 || >=22.0.0"
  }
}
