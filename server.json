{
  "name": "com.socialneuron/mcp-server",
  "display_name": "Social Neuron",
  "description": "52 MCP tools for AI-powered social media content lifecycle. Generate, schedule, and optimize content across YouTube, TikTok, and Instagram using Claude Code, Cursor, or any MCP client. Performance analytics feed back into content generation automatically.",
  "version": "1.5.2",
  "homepage": "https://socialneuron.com/for-developers",
  "repository": "https://github.com/socialneuron/mcp-server",
  "license": "MIT",
  "author": {
    "name": "Social Neuron",
    "url": "https://socialneuron.com"
  },
  "categories": ["social-media", "content-creation", "analytics", "marketing", "automation"],
  "tools_count": 52,
  "transport": ["stdio", "streamable-http"],
  "source_entry": "src/index.ts",
  "package": {
    "name": "@socialneuron/mcp-server",
    "registry": "https://registry.npmjs.org"
  },
  "install": {
    "command": "npx",
    "args": ["-y", "@socialneuron/mcp-server"]
  },
  "endpoints": {
    "stdio": {
      "command": "npx",
      "args": ["-y", "@socialneuron/mcp-server"]
    },
    "http": {
      "url": "https://mcp.socialneuron.com/mcp",
      "transport": "streamable-http"
    }
  },
  "auth": {
    "type": "api_key",
    "setup_url": "https://socialneuron.com/settings/developer",
    "docs_url": "https://socialneuron.com/for-developers"
  },
  "env": [
    {
      "name": "SOCIALNEURON_API_KEY",
      "description": "Your Social Neuron API key. Generate at https://socialneuron.com/settings/developer",
      "required": true
    }
  ],
  "pricing": {
    "has_free_tier": false,
    "starting_price": "$29/mo",
    "pricing_url": "https://socialneuron.com/pricing"
  }
}
