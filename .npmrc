# Security hardening — do not remove without security review.
#
# ignore-scripts=true   kills post-install RCE (the #1 npm supply-chain vector)
# allow-git=none        blocks git: deps that could ship their own .npmrc re-enabling scripts
# fund=false            quieter installs
# audit=true            always audit on install
# save-exact=true       no ^ ranges sneaking in via `npm install <pkg>`
# package-lock=true     never silently drop the lockfile
ignore-scripts=true
allow-git=none
fund=false
audit=true
save-exact=true
package-lock=true
